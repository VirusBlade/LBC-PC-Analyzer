{
  "manifest_version": 3,
  "name": "LBC PC Analyzer",
  "version": "0.4.1",
  "description": "Analyse localement les annonces Leboncoin de PC.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://*.workers.dev/*",
    "https://www.leboncoin.fr/*",
    "https://leboncoin.fr/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.leboncoin.fr/*",
        "https://leboncoin.fr/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
